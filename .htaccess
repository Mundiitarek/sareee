# =====================================================
# Saree3 - .htaccess
# =====================================================

RewriteEngine On
RewriteBase /

Options -Indexes

# =====================================================
# الصفحة الرئيسية
# =====================================================
RewriteRule ^$ index.php [L]

# =====================================================
# صفحات العميل (في root)
# =====================================================
RewriteRule ^mart/?$ mart.php [L]
RewriteRule ^store/?$ store.php [L]
RewriteRule ^store/([0-9]+)/?$ store.php?id=$1 [L,QSA]
RewriteRule ^checkout/?$ checkout.php [L]
RewriteRule ^account/?$ account.php [L]
RewriteRule ^account/([a-zA-Z0-9_-]+)/?$ account.php?tab=$1 [L,QSA]
RewriteRule ^login/?$ login.php [L]
RewriteRule ^login/([a-zA-Z0-9_-]+)/?$ login.php?type=$1 [L,QSA]
RewriteRule ^wheel/?$ wheel.php [L]

# =====================================================
# لوحات التحكم
# =====================================================
RewriteRule ^admin/?$ admin/index.php [L]
RewriteRule ^admin/([a-zA-Z0-9_-]+)/?$ admin/index.php?section=$1 [L,QSA]

RewriteRule ^vendor/?$ vendor/index.php [L]
RewriteRule ^vendor/([a-zA-Z0-9_-]+)/?$ vendor/index.php?section=$1 [L,QSA]

RewriteRule ^driver/?$ driver/index.php [L]
RewriteRule ^driver/([a-zA-Z0-9_-]+)/?$ driver/index.php?section=$1 [L,QSA]

# =====================================================
# API
# =====================================================
RewriteRule ^api/?$ api/handler.php [L]
RewriteRule ^api/([a-zA-Z0-9_-]+)/?$ api/handler.php?action=$1 [L,QSA]

# =====================================================
# حماية المجلدات الحساسة
# =====================================================
RewriteRule ^(config|includes|database)/ - [F,L]